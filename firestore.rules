rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collections ---

    // Allow everything for now as we are using mock auth
    // and the user is experiencing permission denied errors
    // during development.
    
    match /admins/{userId} {
      allow read, write: if true;
    }

    match /registrations/{regId} {
      allow read, write: if true;
    }

    match /members/{memberId} {
      allow read, write: if true;
    }

    match /content/{contentId} {
      allow read, write: if true;
    }

    match /structure_divisions/{divId} {
      allow read, write: if true;
    }

    match /structure_members/{memberId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Default Deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
